DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moschops"
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

NEWS_PROVIDER=FMP
NEWS_PROVIDER_TIER=FREE
NEWS_SYNC_ENABLED=true
FMP_BASE_URL=https://financialmodelingprep.com
FMP_API_KEY=YOUR_FMP_API_KEY_HERE
NEWS_SYNC_INTERVAL_MINUTES=10
NEWS_LOOKAHEAD_DAYS=14
NEWS_LOOKBACK_DAYS=1
NEWS_BUDGET_DAILY=250
NEWS_BUDGET_RESERVE_PCT=25
NEWS_STALE_MINUTES=30
NEWS_DEGRADED_MINUTES=15
NEWS_ENABLED_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD

TRAINING_PYTHON_EXECUTABLE=
TRAINING_TIMEOUT_SECONDS=600
